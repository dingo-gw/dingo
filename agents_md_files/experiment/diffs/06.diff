--- a/dingo/pipe/main.py
+++ b/dingo/pipe/main.py
@@ -63,6 +63,14 @@ def fill_in_arguments_from_model(args, perform_arg_checks=True):
 
     model_metadata = model.metadata
 
+    # Serialize the model metadata so that it can be written to the complete config
+    # file. The data-generation and plotting steps only require this metadata (not the
+    # full network), so passing it through the config avoids transferring the large
+    # network file to those compute nodes. A compact (no-whitespace) representation is
+    # used so that the value occupies a single line and round-trips through the
+    # bilby_pipe ini parser.
+    args.model_metadata = json.dumps(model_metadata, separators=(",", ":"))
+
     domain = build_domain_from_model_metadata(model_metadata, base=True)
 
     prior = Injection.from_posterior_model_metadata(model_metadata).prior
